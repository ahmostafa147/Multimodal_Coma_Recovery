{
  "data": {
    "neural_dir": "test_data",
    "labels_path": "test_data/labels/test_clinical.csv",
    "train_ids": "test_data/train_ids.csv",
    "test_ids": "test_data/test_ids.csv",
    "nan_strategy": "mean",
    "seed": 42,
    "n_workers": 1
  },
  "cebra": {
    "model_architecture": "offset10-model",
    "batch_size": 32,
    "learning_rate": 0.001,
    "temperature": 1.0,
    "max_iterations": 100,
    "time_offsets": 5,
    "output_dimension": 3
  },
  "sweep": {
    "param_grid": {
      "learning_rate": [0.001, 0.003],
      "temperature": [1.0, 1.12],
      "output_dimension": [3],
      "max_iterations": [50, 100]
    },
    "max_train_samples": 10000,
    "max_plot_points": 5000
  }
}
